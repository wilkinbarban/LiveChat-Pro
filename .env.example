# ============================================================
# LiveChat Pro — Environment variables
# Copy this file to .env and replace the example values.
# Never commit a real .env file.
# ============================================================

# ============================================================
# 1. Telegram
# ============================================================
# Telegram bot token created with @BotFather.
TELEGRAM_TOKEN="123456789:ABCdefGhiJKlmNOpqrSTUvwxYZ"

# Numeric Telegram user/chat ID that receives visitor messages and can reply.
TELEGRAM_ADMIN_ID="123456789"

# Maximum time to wait for Telegram bot startup, in milliseconds.
TELEGRAM_LAUNCH_TIMEOUT_MS="15000"

# ============================================================
# 2. Server
# ============================================================
# Internal HTTP port used by the Node.js server.
PORT="3000"

# Public Docker host port. Use 8080 by default so 80/443 remain available for nginx.
HOST_PORT="8080"

# Runtime environment. Options: development, production, test.
# production enables secure cookie behavior and assumes HTTPS/reverse proxy usage.
NODE_ENV="production"

# Allowed origins for the widget/admin API. Use * only for local development.
# Production example: https://example.com,https://www.example.com
ALLOWED_ORIGINS="https://example.com,https://www.example.com"

# Password for the /admin web panel. Use a long random value in production.
ADMIN_PANEL_PASSWORD="change-this-strong-password"

# Language used by the admin panel and translated admin messages.
# Options: es, en, pt, fr, de, it.
ADMIN_LANGUAGE="en"

# Admin session lifetime in hours.
ADMIN_SESSION_TTL_HOURS="12"

# Log verbosity. Options: trace, debug, info, warn, error, fatal, silent.
LOG_LEVEL="info"

# Number of trusted reverse proxy hops. Use 1 behind nginx/Traefik on the same host.
TRUST_PROXY_HOPS="1"

# Cookie SameSite policy. Options: lax, strict, none. Use none only with HTTPS.
COOKIE_SAME_SITE="lax"

# ============================================================
# 3. Widget
# ============================================================
# Chat launcher style. Options: floating, bubble, tab, hidden.
WIDGET_BUTTON_STYLE="floating"

# Primary widget color in HEX format.
WIDGET_PRIMARY_COLOR="#4F46E5"

# Optional custom welcome message. Leave empty for automatic localized greetings.
WIDGET_WELCOME_MESSAGE="Hello! How can we help you today?"

# Optional public widget API key. Leave empty to disable API-key validation.
WIDGET_API_KEY="lcp_public_example_key_123"

# ============================================================
# 4. Features (on/off flags)
# ============================================================
# Enable automatic message translation. Options: true, false.
FEATURE_TRANSLATION="true"

# Enable basic sentiment detection for visitor messages. Options: true, false.
FEATURE_SENTIMENT="true"

# Show realistic admin typing indicators. Options: true, false.
FEATURE_GHOST_TYPING="true"

# Enable IP-based geolocation lookup. Options: true, false.
FEATURE_GEOLOCATION="true"

# ============================================================
# 5. Translation
# ============================================================
# Translation provider. Options: google_free, google_cloud, deepl.
# google_free needs no API key and is the default fallback.
TRANSLATION_PROVIDER="google_free"

# API key for google_cloud or deepl. Leave empty when using google_free.
TRANSLATION_API_KEY=""

# Optional DeepL-compatible endpoint, for example https://api.deepl.com/v2/translate.
DEEPL_API_URL="https://api.deepl.com/v2/translate"

# ============================================================
# 6. Rate Limiting
# ============================================================
# Time window for public/admin/login rate limits, in minutes.
RATE_LIMIT_WINDOW_MINUTES="15"

# Maximum public API/widget requests per window per IP.
RATE_LIMIT_PUBLIC_MAX="300"

# Maximum admin API requests per window per IP.
RATE_LIMIT_ADMIN_MAX="2000"

# Maximum login attempts per window per IP.
RATE_LIMIT_LOGIN_MAX="20"

# Time window for upload rate limits, in minutes.
RATE_LIMIT_UPLOAD_WINDOW_MINUTES="1"

# Maximum image uploads per upload window per IP.
RATE_LIMIT_UPLOAD_MAX="10"

# ============================================================
# 7. Image Attachments
# ============================================================
# Maximum uploaded image size in megabytes.
MAX_UPLOAD_MB="5"

# Directory where uploaded images are stored.
UPLOAD_DIR="data/uploads"

# Comma-separated list of accepted image MIME types.
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp,image/gif"

# ============================================================
# 8. Redis (optional)
# ============================================================
# Optional Redis connection URL for multi-node Socket.IO/session scaling.
# Leave empty to use in-memory single-node behavior.
REDIS_URL="redis://localhost:6379"

# Prefix for Redis keys used by LiveChat Pro.
REDIS_KEY_PREFIX="lcp"

# Enable or disable Redis scaling. Options: true, false.
# Defaults to false on Windows (to prevent connection delays if not running) and true elsewhere.
REDIS_ENABLED="true"

# ============================================================
# 9. Smart Bot / AI
# ============================================================
# Bot operating mode. Options:
# - disabled: no automatic bot; all visitor messages go to Telegram/admin.
# - knowledge-base: answer from data/knowledge-base.json using fuzzy matching.
# - ai: use OpenAI-compatible AI responses with conversation context.
BOT_MODE="knowledge-base"

# OpenAI API key. Required only when BOT_MODE=ai.
OPENAI_API_KEY="sk-proj-example1234567890"

# OpenAI model used when BOT_MODE=ai. Example options: gpt-4o-mini, gpt-4o, gpt-4.1-mini.
OPENAI_MODEL="gpt-4o-mini"

# Maximum number of AI output tokens per bot reply.
OPENAI_MAX_TOKENS="300"

# System prompt that defines the AI assistant behavior when BOT_MODE=ai.
BOT_SYSTEM_PROMPT="You are a friendly support assistant. Be brief, accurate, and reply in the user's language. Escalate to a human when unsure."

# Confidence threshold for knowledge-base answers, from 0.0 to 1.0.
# Higher values reduce wrong answers but escalate more often; lower values answer more aggressively.
BOT_CONFIDENCE_THRESHOLD="0.60"

# Number of recent conversation messages sent as context when BOT_MODE=ai.
BOT_CONTEXT_MESSAGES="6"

# Notify the Telegram admin when the bot replies automatically. Options: true, false.
BOT_NOTIFY_ADMIN="false"

# ============================================================
# 10. Knowledge Base Training
# ============================================================
# kb-trainer is a separate CLI script:
#   node kb-trainer/index.js
#
# The options below are NOT .env variables used by the server. They are documented
# here as a quick reference for the kb-trainer CLI flags.
#
# Providers:
#   none, openrouter, groq, gemini, openai, xai, anthropic, mistral, cohere, ollama, custom
#
# Common flags:
#   --provider <provider>       AI provider to use; use none for no API key.
#   --key <api-key>             Provider API key when required.
#   --model <model>             Override the provider default model.
#   --base-url <url>            Custom/OpenAI-compatible endpoint for custom or ollama.
#   --urls <items>              Comma-separated URLs or local files to import.
#   --mode append|replace       Append to or replace the existing knowledge base.
#   --output <file>             Output file; default: data/knowledge-base.json.
#   --lang <code>               Knowledge-base language, for example en, es, pt.
#   --dry-run                   Preview generated entries without writing the file.
#
# Examples:
#   node kb-trainer/index.js --provider none --urls "https://example.com/faq,docs/manual.md" --mode append --lang en
#   node kb-trainer/index.js --provider openrouter --key sk-or-xxx --urls "https://example.com" --model meta-llama/llama-3.1-8b-instruct:free
#   node kb-trainer/index.js --provider groq --key gsk_xxx --model llama-3.1-8b-instant --urls "docs/faq.md"
#   node kb-trainer/index.js --provider ollama --base-url http://localhost:11434/v1 --model llama3 --urls "README.md"
#   node kb-trainer/index.js --provider custom --base-url http://localhost:1234/v1 --model local-model --urls "README.md"
