# ============================================================
# LiveChat Pro — Variables de entorno
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a git
# ============================================================

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_TOKEN="123456789:ABCdefGhiJKlmNOpqrSTUvwxYZ"
TELEGRAM_ADMIN_ID="123456789"

# ── Servidor ──────────────────────────────────────────────────
PORT="3000"
# Puerto publicado por Docker en el VPS. Por defecto usa 8080 para dejar 80/443 libres.
HOST_PORT="8080"

# NODE_ENV=production activa cookies Secure (requiere HTTPS / nginx)
# NODE_ENV="production"

# CORS: dominio(s) permitidos para el widget (usa * solo en desarrollo)
# Ejemplo para producción: ALLOWED_ORIGINS=https://tuweb.com,https://otra.com
ALLOWED_ORIGINS="*"
ADMIN_PANEL_PASSWORD="cambia-esta-clave"
# Idioma en que el admin verá mensajes traducidos: es, en, pt, fr, de, it
ADMIN_LANGUAGE="es"
ADMIN_SESSION_TTL_HOURS="12"
LOG_LEVEL="info"
TRUST_PROXY_HOPS="1"
TELEGRAM_LAUNCH_TIMEOUT_MS="15000"
# lax, strict o none. Usa none solo si sirves admin sobre HTTPS.
COOKIE_SAME_SITE="lax"

# ── Widget ────────────────────────────────────────────────────
WIDGET_BUTTON_STYLE="floating"
WIDGET_PRIMARY_COLOR="#4F46E5"
# Déjalo vacío para usar el saludo automático en español, inglés o portugués.
WIDGET_WELCOME_MESSAGE=""
WIDGET_API_KEY=""

# ── Funciones (true/false) ────────────────────────────────────
FEATURE_TRANSLATION="true"
FEATURE_SENTIMENT="true"
FEATURE_GHOST_TYPING="true"
FEATURE_GEOLOCATION="true"

# ── Traducción ────────────────────────────────────────────────
# google_free no requiere clave y se usa como fallback.
# Opciones: google_free, google_cloud, deepl
TRANSLATION_PROVIDER="google_free"
TRANSLATION_API_KEY=""
# Opcional: endpoint alternativo para DeepL, por ejemplo https://api.deepl.com/v2/translate
DEEPL_API_URL=""

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MINUTES="15"
RATE_LIMIT_PUBLIC_MAX="300"
RATE_LIMIT_ADMIN_MAX="2000"
RATE_LIMIT_LOGIN_MAX="20"
RATE_LIMIT_UPLOAD_WINDOW_MINUTES="1"
RATE_LIMIT_UPLOAD_MAX="10"

# ── Adjuntos de imagen ────────────────────────────────────────
MAX_UPLOAD_MB="5"
UPLOAD_DIR="data/uploads"
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp,image/gif"

# ── Redis (opcional, recomendado para multi-nodo) ─────────────
REDIS_URL=""
REDIS_KEY_PREFIX="lcp"
